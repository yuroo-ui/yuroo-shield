# Etherscan v2 unified multi-chain API (https://docs.etherscan.io/etherscan-v2)
ETHERSCAN_API_KEY=your-etherscan-v2-key

# LLM (any OpenAI-compatible endpoint). Optional — agents fall back to heuristics.
# Examples:
#   LLM_BASE_URL=https://api.openai.com/v1                  + LLM_MODEL=gpt-4o-mini
#   LLM_BASE_URL=https://openrouter.ai/api/v1               + LLM_MODEL=anthropic/claude-3.5-haiku
#   LLM_BASE_URL=https://api.xiaomimimo.com/v1              + LLM_MODEL=mimo-v2.5-pro
#   LLM_BASE_URL=http://localhost:8080/v1                   + LLM_MODEL=local
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Risk thresholds
HOLDER_CONCENTRATION_THRESHOLD=0.5
MIN_HOLDERS_SAFE=1000
